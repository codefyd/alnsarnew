function حفظ_قالب_رسالة(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بتعديل القوالب" };
  }

  const sh = _getSheet(SHEETS.قوالب_الرسائل);
  let row = null;

  if (data._صف) {
    const rows = قراءة_كائنات_شيت_مع_كاش(SHEETS.قوالب_الرسائل, 15);
    row = rows.find(x => Number(x._صف) === Number(data._صف));
  }

  if (!row && data.عنوان_القالب) {
    row = جلب_صف_بـ( sh, "عنوان_القالب", data.عنوان_القالب );
  }

  if (!row) return { نجاح: false, خطأ: "القالب غير موجود" };

  _updateRowByHeader(SHEETS.قوالب_الرسائل, row._صف || row.صف, {
    "عنوان_القالب": data.عنوان_القالب || row["عنوان_القالب"] || "",
    "نص_القالب": data.نص_القالب || row["نص_القالب"] || "",
    "نوع_القالب": data.نوع_القالب || row["نوع_القالب"] || "",
    "المتغيرات": data.المتغيرات || row["المتغيرات"] || ""
  });

  return { نجاح: true, رسالة: "تم حفظ القالب" };
}

function جلب_عتبات_الانذارات(data) {
  const عتبات = قراءة_كائنات_شيت_مع_كاش(SHEETS.عتبات_الانذارات, 120)
    .sort((a, b) => {
      const t = String(a["نوع_المخالفة"] || "").localeCompare(String(b["نوع_المخالفة"] || ""), 'ar');
      if (t !== 0) return t;
      return Number(a["رقم_العتبة"] || 0) - Number(b["رقم_العتبة"] || 0);
    });
  return { نجاح: true, عتبات };
}

function حفظ_عتبات_الانذارات(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بتعديل العتبات" };
  }

  const النوع = String(data.نوع_المخالفة || "").trim();
  const عتبات = Array.isArray(data.عتبات) ? data.عتبات : [];
  if (!النوع || !عتبات.length) return { نجاح: false, خطأ: "بيانات العتبات غير مكتملة" };

  const sh = _getSheet(SHEETS.عتبات_الانذارات);

  عتبات.forEach(item => {
    const row = قراءة_كائنات_شيت_مع_كاش(SHEETS.عتبات_الانذارات, 10).find(x =>
      String(x["نوع_المخالفة"] || "") === النوع &&
      Number(x["رقم_العتبة"] || 0) === Number(item["رقم_العتبة"] || 0)
    );

    if (row) {
      _updateRowByHeader(SHEETS.عتبات_الانذارات, row._صف, {
        "عدد_المخالفات_للاستحقاق": item["عدد_المخالفات_للاستحقاق"] || "",
        "الإجراء_الافتراضي": item["الإجراء_الافتراضي"] || ""
      });
    } else {
      _appendRow(SHEETS.عتبات_الانذارات, [
        النوع,
        item["رقم_العتبة"] || "",
        item["عدد_المخالفات_للاستحقاق"] || "",
        item["الإجراء_الافتراضي"] || ""
      ]);
    }
  });

  تنظيف_كاش_شيتات();
  return { نجاح: true, رسالة: "تم حفظ العتبات" };
}

function جلب_الاجراءات(data) {
  let إجراءات = قراءة_كائنات_شيت_مع_كاش(SHEETS.الاجراءات, 120);

  if (data.نوع_الاجراء) {
    إجراءات = إجراءات.filter(x => String(x["نوع_الاجراء"] || "") === String(data.نوع_الاجراء));
  }

  إجراءات.sort((a, b) => {
    const t = String(a["نوع_الاجراء"] || "").localeCompare(String(b["نوع_الاجراء"] || ""), 'ar');
    if (t !== 0) return t;
    return Number(a["الترتيب"] || 0) - Number(b["الترتيب"] || 0);
  });

