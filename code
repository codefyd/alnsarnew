function إضافة_إجراء(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بإضافة إجراء" };
  }

  const النوع = String(data.نوع_الاجراء || "").trim();
  const الاسم = String(data.اسم_الاجراء || "").trim();
  if (!النوع || !الاسم) return { نجاح: false, خطأ: "نوع الإجراء واسمه مطلوبان" };

  const rows = قراءة_كائنات_شيت_مع_كاش(SHEETS.الاجراءات, 30);
  if (rows.find(x => String(x["اسم_الاجراء"] || "") === الاسم && String(x["نوع_الاجراء"] || "") === النوع)) {
    return { نجاح: false, خطأ: "الإجراء موجود مسبقاً" };
  }

  const maxOrder = rows
    .filter(x => String(x["نوع_الاجراء"] || "") === النوع)
    .reduce((m, x) => Math.max(m, Number(x["الترتيب"] || 0)), 0);

  _appendRow(SHEETS.الاجراءات, [النوع, الاسم, maxOrder + 1, "نعم"]);
  return { نجاح: true, رسالة: "تمت إضافة الإجراء" };
}

function حذف_إجراء(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بحذف الإجراء" };
  }

  const sh = _getSheet(SHEETS.الاجراءات);
  const row = جلب_صف_بـ( sh, "اسم_الاجراء", data.اسم_الاجراء );
  if (!row) return { نجاح: false, خطأ: "الإجراء غير موجود" };

  sh.deleteRow(row.صف);
  تنظيف_كاش_شيتات();
  return { نجاح: true, رسالة: "تم حذف الإجراء" };
}

