function إضافة_عامل(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بإضافة عامل" };
  }

  const الاسم = String(data.الاسم || "").trim();
  const الرمز = String(data.رمز_الدخول || "").trim();
  if (!الاسم || !الرمز) return { نجاح: false, خطأ: "الاسم ورمز الدخول مطلوبان" };

  const rows = قراءة_كائنات_شيت_مع_كاش(SHEETS.العاملون, 30);
  if (rows.find(x => String(x["الاسم"] || "") === الاسم)) {
    return { نجاح: false, خطأ: "يوجد مستخدم بنفس الاسم" };
  }

  _appendRow(SHEETS.العاملون, [
    الاسم,
    data.الوظيفة || "",
    data.الحلقة || "",
    الرمز,
    data.رقم_الجوال || "",
    new Date().toISOString(),
    "نعم"
  ]);

  return { نجاح: true, رسالة: "تمت إضافة العامل" };
}

function تعديل_عامل(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بتعديل العامل" };
  }

  const الاسم_القديم = String(data.الاسم_القديم || "").trim();
  if (!الاسم_القديم) return { نجاح: false, خطأ: "اسم العامل مطلوب" };

  const sh = _getSheet(SHEETS.العاملون);
  const row = جلب_صف_بـ( sh, "الاسم", الاسم_القديم );
  if (!row) return { نجاح: false, خطأ: "العامل غير موجود" };

  const updates = {};
  ["الاسم","الوظيفة","الحلقة","رمز_الدخول","رقم_الجوال","نشط"].forEach(k => {
    if (data[k] !== undefined && data[k] !== "") updates[k] = data[k];
  });

  if (!Object.keys(updates).length) {
    return { نجاح: false, خطأ: "لا توجد بيانات للتعديل" };
  }

  _updateRowByHeader(SHEETS.العاملون, row.صف, updates);
  return { نجاح: true, رسالة: "تم تعديل العامل" };
}

function حذف_عامل(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بحذف/تعطيل العامل" };
