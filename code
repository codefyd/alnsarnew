function جلب_الاعدادات(data) {
  const rows = قراءة_كائنات_شيت_مع_كاش(SHEETS.الاعدادات, 120);
  return { نجاح: true, اعدادات: rows };
}

function حفظ_إعداد(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بتعديل الإعدادات" };
  }

  const المفتاح = String(data.المفتاح || "").trim();
  if (!المفتاح) return { نجاح: false, خطأ: "المفتاح مطلوب" };

  const sh = _getSheet(SHEETS.الاعدادات);
  const row = جلب_صف_بـ(sh, "المفتاح", المفتاح);

  if (row) {
    _updateRowByHeader(SHEETS.الاعدادات, row.صف, {
      "القيمة": data.القيمة || "",
      "الوصف": data.الوصف || ""
    });
  } else {
    _appendRow(SHEETS.الاعدادات, [المفتاح, data.القيمة || "", data.الوصف || ""]);
  }

  return { نجاح: true, رسالة: "تم حفظ الإعداد" };
}

function جلب_الحلق(data) {
  const حلق = قراءة_كائنات_شيت_مع_كاش(SHEETS.الحلق, 60)
    .sort((a, b) => String(a["اسم_الحلقة"] || "").localeCompare(String(b["اسم_الحلقة"] || ""), 'ar'));
  return { نجاح: true, حلق };
}

function إضافة_حلقة(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بإضافة حلقة" };
  }

  const اسم_الحلقة = String(data.اسم_الحلقة || "").trim();
  if (!اسم_الحلقة) return { نجاح: false, خطأ: "اسم الحلقة مطلوب" };

  const موجود = قراءة_كائنات_شيت_مع_كاش(SHEETS.الحلق, 60)
    .find(x => String(x["اسم_الحلقة"] || "") === اسم_الحلقة);
  if (موجود) return { نجاح: false, خطأ: "الحلقة موجودة مسبقاً" };

  _appendRow(SHEETS.الحلق, [
    اسم_الحلقة,
    data.المعلم || "",
    data.المرحلة || "",
    data.عدد_الطلاب || "",
    data.ملاحظات || ""
  ]);

  return { نجاح: true, رسالة: "تمت إضافة الحلقة" };
}

function حذف_حلقة(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بحذف الحلقة" };
  }

  const sh = _getSheet(SHEETS.الحلق);
  const row = جلب_صف_بـ(sh, "اسم_الحلقة", data.اسم_الحلقة);
  if (!row) return { نجاح: false, خطأ: "الحلقة غير موجودة" };

  sh.deleteRow(row.صف);
  تنظيف_كاش_شيتات();
  return { نجاح: true, رسالة: "تم حذف الحلقة" };
}

function جلب_العاملين_admin(data) {
