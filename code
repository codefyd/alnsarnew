      "تاريخ_الميلاد","الحي_العنوان","المرحلة_الدراسية","الصف_الدراسي",
      "اسم_ولي_الامر","رقم_جوال_ولي_الامر","رقم_هوية_ولي_الامر",
      "صلة_ولي_الامر","حالة_الطلب","سبب_الرفض","الحلقة_المسكنة",
      "تاريخ_الطلب","تاريخ_المعالجة"
    ],
    [SHEETS.طلبات_التعديل]: [
      "رقم_الطلب","رقم_الطالب","اسم_الطالب","الحقل_المراد_تعديله",
      "القيمة_القديمة","القيمة_الجديدة","حالة_الطلب","تاريخ_الطلب","تاريخ_المعالجة"
    ],
    [SHEETS.الحلق]: [
      "اسم_الحلقة","المعلم","المرحلة","عدد_الطلاب","ملاحظات"
    ],
    [SHEETS.العاملون]: [
      "الاسم","الوظيفة","الحلقة","رمز_الدخول","رقم_الجوال","تاريخ_الإضافة","نشط"
    ],
    [SHEETS.الانذارات_التعليمية]: [
      "رقم_الانذار","رقم_الطالب","اسم_الطالب","الحلقة",
      "سبب_الانذار","حالة_الإجراء","اسم_المشرف","تاريخ_الإصدار","تاريخ_الإغلاق","ملاحظات"
    ],
    [SHEETS.الانذارات_الادارية]: [
      "رقم_الانذار","رقم_الطالب","اسم_الطالب","الحلقة",
      "نوع_الانذار","رقم_العتبة","عدد_المخالفات","حالة_الإجراء",
      "تاريخ_الاستحقاق","تاريخ_الإغلاق","ملاحظات"
    ],
    [SHEETS.سجل_الحضور]: [
      "رقم_الطالب","اسم_الطالب","الحلقة","التاريخ",
      "نوع_الغياب","ملاحظة"
      // نوع_الغياب: حضور / غياب / غياب_بعذر / تأخر
    ],
    [SHEETS.الاعدادات]: [
      "المفتاح","القيمة","الوصف"
    ],
    [SHEETS.قوالب_الرسائل]: [
      "نوع_القالب","عنوان_القالب","نص_القالب","المتغيرات"
    ],
    [SHEETS.عتبات_الانذارات]: [
      "نوع_المخالفة","رقم_العتبة","عدد_المخالفات_للاستحقاق","الإجراء_الافتراضي"
    ],
    [SHEETS.الاجراءات]: [
      "نوع_الاجراء","اسم_الاجراء","الترتيب","نشط"
      // نوع_الاجراء: تعليمي / تأخر / غياب / غياب_بعذر
    ],
    [SHEETS.حالات_الطالب]: [
      "اسم_الحالة","اللون","الترتيب"
    ],
  };

  const أوامر_التهيئة = [];

  for (const [اسم, أعمدة] of Object.entries(تعريف_الشيتات)) {
    let sheet = ss.getSheetByName(اسم);
        if (!sheet) {
      sheet = ss.insertSheet(اسم);
      أوامر_التهيئة.push({ sheet, أعمدة, جديد: true });
    } else {
      const آخر_عمود = Math.max(sheet.getLastColumn(), 1);
      const رأس_موجود = sheet.getRange(1, 1, 1, آخر_عمود).getValues()[0];
      const مفقودة = أعمدة.filter(ع => !رأس_موجود.includes(ع));
      if (مفقودة.length > 0) {
        const عمود_بداية = sheet.getLastColumn() + 1;
        sheet.getRange(1, عمود_بداية, 1, مفقودة.length).setValues([مفقودة]);
      }
    }
  }

  for (const { sheet, أعمدة } of أوامر_التهيئة) {
    sheet.getRange(1, 1, 1, أعمدة.length).setValues([أعمدة]);
    sheet.getRange(1, 1, 1, أعمدة.length)
      .setBackground("#1a5276")
      .setFontColor("#ffffff")
      .setFontWeight("bold")
      .setHorizontalAlignment("center");
    sheet.setRightToLeft(true);
    sheet.setFrozenRows(1);
    sheet.autoResizeColumns(1, أعمدة.length);
  }

  تهيئة_البيانات_الافتراضية(ss);
  SpreadsheetApp.flush();
