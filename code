function جلب_عتبات_حسب_النوع(النوع) {
  return قراءة_كائنات_شيت_مع_كاش(SHEETS.عتبات_الانذارات, 60)
    .filter(x => String(x["نوع_المخالفة"] || "") === String(النوع || ""))
    .sort((a, b) => Number(a["رقم_العتبة"] || 0) - Number(b["رقم_العتبة"] || 0));
}

function جلب_الأرشيف_الإداري_للطالب(رقم_الطالب, النوع) {
  return قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_الادارية, 30)
    .filter(x =>
      String(x["رقم_الطالب"] || "") === String(رقم_الطالب || "") &&
      String(x["نوع_الانذار"] || "") === String(النوع || "")
    )
    .sort((a, b) => Number(a["رقم_العتبة"] || 0) - Number(b["رقم_العتبة"] || 0));
}

function حساب_عدد_المخالفات_للطالب(رقم_الطالب, النوع) {
  const سجلات = قراءة_كائنات_شيت_مع_كاش(SHEETS.سجل_الحضور, 30)
    .filter(x =>
      String(x["رقم_الطالب"] || "") === String(رقم_الطالب || "") &&
      String(x["نوع_الغياب"] || "") === String(النوع || "")
    );
  return سجلات.length;
}

function جلب_مستحقي_الانذار_الاداري(data) {
  const session = data._session || {};
  const role = String(session.الوظيفة || "");
  if (!["مشرف_اداري","مدير"].includes(role)) {
    return { نجاح: false, خطأ: "غير مصرح لك بعرض المستحقين للإنذار الإداري" };
  }

  const mapType = {
    "تأخر": "تأخر",
    "غياب": "غياب",
    "غياب_بعذر": "غياب_بعذر"
  };

  const النوع = mapType[data.نوع] || "";
  if (!النوع) return { نجاح: true, طلاب: [] };

  const الطلاب = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 45);
  const أولياء = قراءة_كائنات_شيت_مع_كاش(SHEETS.اولياء_الامر, 45);
  const العتبات = جلب_عتبات_حسب_النوع(النوع);
  const أرشيف = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_الادارية, 30)
    .filter(x => String(x["نوع_الانذار"] || "") === النوع);

  const result = [];

  الطلاب.forEach(ط => {
    const رقم_الطالب = ط["رقم_الطالب"];
    const عدد_المخالفات = حساب_عدد_المخالفات_للطالب(رقم_الطالب, النوع);
    if (!عدد_المخالفات) return;

    const أرشيف_الطالب = أرشيف
      .filter(x => String(x["رقم_الطالب"] || "") === String(رقم_الطالب))
      .sort((a, b) => Number(a["رقم_العتبة"] || 0) - Number(b["رقم_العتبة"] || 0));

    const أعلى_عتبة_منفذة = أرشيف_الطالب.length
      ? Math.max(...أرشيف_الطالب.map(x => Number(x["رقم_العتبة"] || 0)))
      : 0;

    const العتبة_القادمة = العتبات.find(t =>
      Number(t["رقم_العتبة"] || 0) === أعلى_عتبة_منفذة + 1 &&
      عدد_المخالفات >= Number(t["عدد_المخالفات_للاستحقاق"] || 0)
    );

    if (!العتبة_القادمة) return;

    const ولي = أولياء.find(w => String(w["رقم_الطالب"] || "") === String(رقم_الطالب)) || {};

    result.push({
      رقم_الطالب: رقم_الطالب,
      اسم_الطالب: ط["اسم_الطالب"] || "",
      الحلقة: ط["الحلقة"] || "",
      المرحلة_الدراسية: ط["المرحلة_الدراسية"] || "",
      رقم_العتبة: Number(العتبة_القادمة["رقم_العتبة"] || 0),
      عدد_المخالفات: عدد_المخالفات,
      الإجراء_المقترح: العتبة_القادمة["الإجراء_الافتراضي"] || "",
      رقم_جوال_ولي_الامر: ولي["رقم_جوال_ولي_الامر"] || "",
      اسم_ولي_الامر: ولي["اسم_ولي_الامر"] || ""
    });
  });

  result.sort((a, b) => {
    if (a.رقم_العتبة !== b.رقم_العتبة) return a.رقم_العتبة - b.رقم_العتبة;
    return String(a.اسم_الطالب || "").localeCompare(String(b.اسم_الطالب || ""), 'ar');
  });

  return { نجاح: true, طلاب: result };
}

function تحديث_إجراء_انذار_اداري(data) {
  const session = data._session || {};
  const role = String(session.الوظيفة || "");
  if (!["مشرف_اداري","مدير"].includes(role)) {
    return { نجاح: false, خطأ: "غير مصرح لك بتحديث الإنذار الإداري" };
  }

  const نوع_الانذار = String(data.نوع_الانذار || "").trim();
  const رقم_الطالب = String(data.رقم_الطالب || "").trim();
  const رقم_العتبة = Number(data.رقم_العتبة || 0);

  if (!نوع_الانذار || !رقم_الطالب || !رقم_العتبة) {
    return { نجاح: false, خطأ: "بيانات الإنذار الإداري غير مكتملة" };
  }

  const موجود = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_الادارية, 20).find(x =>
    String(x["رقم_الطالب"] || "") === رقم_الطالب &&
    String(x["نوع_الانذار"] || "") === نوع_الانذار &&
    Number(x["رقم_العتبة"] || 0) === رقم_العتبة
  );

  if (موجود) {
    const sh = _getSheet(SHEETS.الانذارات_الادارية);
    const updates = {
      "حالة_الإجراء": data.الإجراء || موجود["حالة_الإجراء"] || ""
    };
    if (data.مكتمل) updates["تاريخ_الإغلاق"] = new Date().toISOString();
    if (data.ملاحظات !== undefined) updates["ملاحظات"] = data.ملاحظات;
    _updateRowByHeader(SHEETS.الانذارات_الادارية, موجود._صف, updates);
    return { نجاح: true, رسالة: "تم تحديث الإنذار الإداري" };
  }

  const رقم_الانذار = "ADM-" + Date.now();
  _appendRow(SHEETS.الانذارات_الادارية, [
    رقم_الانذار,
    رقم_الطالب,
    data.اسم_الطالب || "",
    data.الحلقة || "",
    نوع_الانذار,
    رقم_العتبة,
    Number(data.عدد_المخالفات || 0),
    data.الإجراء || "",
    new Date().toISOString(),
    data.مكتمل ? new Date().toISOString() : "",
    data.ملاحظات || ""
  ]);

  return { نجاح: true, رسالة: "تم تسجيل الإنذار الإداري" };
}

function جلب_ارشيف_انذارات_ادارية(data) {
  let list = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_الادارية, 30);

  if (data.نوع_الانذار) {
    list = list.filter(x => String(x["نوع_الانذار"] || "") === String(data.نوع_الانذار));
  }

  if (data.رقم_الطالب) {
    list = list.filter(x => String(x["رقم_الطالب"] || "") === String(data.رقم_الطالب));
  }

  list.sort((a, b) => new Date(b["تاريخ_الاستحقاق"] || 0) - new Date(a["تاريخ_الاستحقاق"] || 0));
  return { نجاح: true, انذارات: list };
}



