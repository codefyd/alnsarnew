// ============================================================
//  دوال مساعدة عامة
// ============================================================
function _sheetToObjects(sheet) {
  if (!sheet || sheet.getLastRow() <= 1) return [];
  const values = sheet.getDataRange().getValues();
  const headers = values[0];
  const rows = [];
  for (let i = 1; i < values.length; i++) {
    const obj = {};
    headers.forEach((h, idx) => obj[h] = values[i][idx]);
    obj._صف = i + 1;
    rows.push(obj);
  }
  return rows;
}

function _getSheet(sheetName) {
  return SpreadsheetApp.getActiveSpreadsheet().getSheetByName(sheetName);
}

function _appendRow(sheetName, row) {
  const sh = _getSheet(sheetName);
  sh.appendRow(row);
  تنظيف_كاش_شيتات();
}

function _findRowByValue(sheet, headerName, value) {
  if (!sheet || sheet.getLastRow() <= 1) return null;
  const values = sheet.getDataRange().getValues();
  const headers = values[0];
  const idx = headers.indexOf(headerName);
  if (idx === -1) return null;
  for (let i = 1; i < values.length; i++) {
    if (String(values[i][idx]) === String(value)) {
      return { صف: i + 1, بيانات: values[i], رؤوس: headers };
    }
  }
  return null;
}

function جلب_صف_بـ(sheet, headerName, value) {
  return _findRowByValue(sheet, headerName, value);
}

function جلب_صف_طلب(sheet, رقم_الطلب) {
  return _findRowByValue(sheet, "رقم_الطلب", رقم_الطلب);
}

function البحث_بالهوية_في_شيت(sheet, identity, oneBasedColumnIndex) {
  if (!sheet || sheet.getLastRow() <= 1) return false;
  const lastRow = sheet.getLastRow();
  const range = sheet.getRange(2, oneBasedColumnIndex, lastRow - 1, 1).getValues();
  const normalized = String(identity || "").trim();
  return range.some(r => String(r[0] || "").trim() === normalized);
}

function _updateRowByHeader(sheetName, rowNumber, updates) {
  const sh = _getSheet(sheetName);
  const headers = sh.getRange(1, 1, 1, sh.getLastColumn()).getValues()[0];
  Object.keys(updates).forEach(key => {
    const idx = headers.indexOf(key);
    if (idx !== -1) {
      sh.getRange(rowNumber, idx + 1).setValue(updates[key]);
    }
  });
  تنظيف_كاش_شيتات();
}

function _normalizePhone(phone) {
  let p = String(phone || "").replace(/\D/g, "");

  // 9665xxxxxxxx -> 5xxxxxxxx
  if (p.startsWith("966") && p.length >= 12) {
    p = p.substring(3);
  }

  // 05xxxxxxxx -> 5xxxxxxxx
  if (p.startsWith("0") && p.length === 10) {
    p = p.substring(1);
  }

  // لو أكثر من 9 أرقام ونهايتها جوال سعودي، خذ آخر 9 أرقام
  if (p.length > 9 && p.startsWith("5")) {
    p = p.substring(0, 9);
  } else if (p.length > 9 && p.substring(p.length - 9).startsWith("5")) {
    p = p.substring(p.length - 9);
  }

  return p;
}

