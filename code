function إصدار_إنذار_تعليمي(data) {
  const session = data._session || {};
  const role = String(session.الوظيفة || "");

  if (!["مشرف_تعليمي","مشرف_اداري","مدير"].includes(role)) {
    return { نجاح: false, خطأ: "غير مصرح لك بإصدار إنذار تعليمي" };
  }

  if (!data.رقم_الطالب || !data.سبب_الانذار) {
    return { نجاح: false, خطأ: "رقم الطالب وسبب الإنذار مطلوبان" };
  }

  const شيت_الطلاب = _getSheet(SHEETS.الطلاب);
  const صف_طالب = جلب_صف_بـ(شيت_الطلاب, "رقم_الطالب", data.رقم_الطالب);
  if (!صف_طالب) return { نجاح: false, خطأ: "الطالب غير موجود" };

  const اسم_الطالب = صف_طالب.بيانات[صف_طالب.رؤوس.indexOf("اسم_الطالب")] || "";
  const الحلقة = صف_طالب.بيانات[صف_طالب.رؤوس.indexOf("الحلقة")] || "";
  const رقم_الانذار = "EDU-" + Date.now();

  _appendRow(SHEETS.الانذارات_التعليمية, [
    رقم_الانذار,
    data.رقم_الطالب,
    اسم_الطالب,
    الحلقة,
    data.سبب_الانذار,
    data.حالة_الإجراء || "بانتظار",
    session.الاسم || "",
    new Date().toISOString(),
    "",
    data.ملاحظات || ""
  ]);

  return { نجاح: true, رسالة: "تم إصدار الإنذار التعليمي", رقم_الانذار };
}

function جلب_الانذارات_التعليمية(data) {
  let list = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_التعليمية, 30);

  if (data.رقم_الطالب) {
    list = list.filter(x => String(x["رقم_الطالب"] || "") === String(data.رقم_الطالب));
  }

  if (data.مفتوح_فقط) {
    list = list.filter(x => !String(x["تاريخ_الإغلاق"] || ""));
  }

  list.sort((a, b) => new Date(b["تاريخ_الإصدار"] || 0) - new Date(a["تاريخ_الإصدار"] || 0));
  return { نجاح: true, انذارات: list };
}

function تحديث_إجراء_انذار_تعليمي(data) {
  const session = data._session || {};
  const role = String(session.الوظيفة || "");

  if (!["مشرف_تعليمي","مشرف_اداري","مدير"].includes(role)) {
    return { نجاح: false, خطأ: "غير مصرح لك بتحديث الإنذار التعليمي" };
  }

  const sh = _getSheet(SHEETS.الانذارات_التعليمية);
  const row = جلب_صف_بـ(sh, "رقم_الانذار", data.رقم_الانذار);
  if (!row) return { نجاح: false, خطأ: "الإنذار غير موجود" };

  const updates = {
    "حالة_الإجراء": data.الإجراء || row.بيانات[row.رؤوس.indexOf("حالة_الإجراء")]
  };

  if (data.مكتمل) {
    updates["تاريخ_الإغلاق"] = new Date().toISOString();
  }

  if (data.ملاحظات !== undefined) {
    updates["ملاحظات"] = data.ملاحظات;
  }

  _updateRowByHeader(SHEETS.الانذارات_التعليمية, row.صف, updates);
  return { نجاح: true, رسالة: "تم تحديث الإنذار التعليمي" };
}



