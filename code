function تسجيل_حضور(data) {
  const session = data._session || {};
  const role = String(session.الوظيفة || "");
  if (!["معلم","مشرف_تعليمي","مشرف_اداري","مدير"].includes(role)) {
    return { نجاح: false, خطأ: "غير مصرح لك بتسجيل الحضور" };
  }

  const رقم_الطالب = String(data.رقم_الطالب || "").trim();
  const التاريخ = String(data.التاريخ || "").trim() || new Date().toISOString().split("T")[0];
  const نوع_الغياب = String(data.نوع_الغياب || "حضور").trim();

  if (!رقم_الطالب) return { نجاح: false, خطأ: "رقم الطالب مطلوب" };

  const شيت_الطلاب = _getSheet(SHEETS.الطلاب);
  const صف_طالب = جلب_صف_بـ(شيت_الطلاب, "رقم_الطالب", رقم_الطالب);
  if (!صف_طالب) return { نجاح: false, خطأ: "الطالب غير موجود" };

  const اسم_الطالب = صف_طالب.بيانات[صف_طالب.رؤوس.indexOf("اسم_الطالب")] || "";
  const الحلقة = صف_طالب.بيانات[صف_طالب.رؤوس.indexOf("الحلقة")] || "";

  if (role === "معلم" && String(session.الحلقة || "") !== String(الحلقة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بتسجيل حضور طالب خارج حلقتك" };
  }

  const موجود = قراءة_كائنات_شيت_مع_كاش(SHEETS.سجل_الحضور, 15).find(x =>
    String(x["رقم_الطالب"] || "") === رقم_الطالب &&
    String(x["التاريخ"] || "") === التاريخ
  );

  if (موجود) {
    _updateRowByHeader(SHEETS.سجل_الحضور, موجود._صف, {
      "نوع_الغياب": نوع_الغياب,
      "ملاحظة": data.ملاحظة || ""
    });
    return { نجاح: true, رسالة: "تم تحديث سجل الحضور" };
  }

  _appendRow(SHEETS.سجل_الحضور, [
    رقم_الطالب,
    اسم_الطالب,
    الحلقة,
    التاريخ,
    نوع_الغياب,
    data.ملاحظة || ""
  ]);

  return { نجاح: true, رسالة: "تم تسجيل الحضور" };
}

function جلب_سجل_حضور_طالب(data) {
  const رقم_الطالب = String(data.رقم_الطالب || "").trim();
  if (!رقم_الطالب) return { نجاح: true, سجلات: [] };

  let list = قراءة_كائنات_شيت_مع_كاش(SHEETS.سجل_الحضور, 30)
    .filter(x => String(x["رقم_الطالب"] || "") === رقم_الطالب);

  if (data.من) {
    list = list.filter(x => String(x["التاريخ"] || "") >= String(data.من));
  }
  if (data.إلى) {
    list = list.filter(x => String(x["التاريخ"] || "") <= String(data.إلى));
  }

  list.sort((a, b) => new Date(b["التاريخ"] || 0) - new Date(a["التاريخ"] || 0));
  return { نجاح: true, سجلات: list };
}



