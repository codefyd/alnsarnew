function تسجيل_طالب_جديد(data) {
  const تحقق = التحقق_من_بيانات_التسجيل(data);
  if (!تحقق.صحيح) return { نجاح: false, خطأ: تحقق.رسالة };

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const شيت_الطلبات = ss.getSheetByName(SHEETS.طلبات_التسجيل);
  const شيت_الطلاب = ss.getSheetByName(SHEETS.الطلاب);

  if (البحث_بالهوية_في_شيت(شيت_الطلاب, data.رقم_الهوية, 3)) {
    return { نجاح: false, خطأ: "هذا الطالب مسجل مسبقاً في المجمع" };
  }
  if (البحث_بالهوية_في_شيت(شيت_الطلبات, data.رقم_الهوية, 3)) {
    return { نجاح: false, خطأ: "يوجد طلب تسجيل سابق لهذا الطالب قيد المراجعة" };
  }

  const رقم_الطلب = "REG-" + Date.now();
  const صف = [
    رقم_الطلب,
    data.اسم_الطالب,
    data.رقم_الهوية,
    data.رقم_جوال_الطالب || "",
    data.تاريخ_الميلاد || "",
    data.الحي_العنوان || "",
    data.المرحلة_الدراسية || "",
    data.الصف_الدراسي || "",
    data.اسم_ولي_الامر || "",
    data.رقم_جوال_ولي_الامر || "",
    data.رقم_هوية_ولي_الامر || "",
    data.صلة_ولي_الامر || "",
    "جديد",
    "",
    "",
    new Date().toISOString(),
    "",
  ];

  _appendRow(SHEETS.طلبات_التسجيل, صف);
  return { نجاح: true, رسالة: "تم إرسال طلب التسجيل بنجاح", رقم_الطلب };
}

function التحقق_من_بيانات_التسجيل(data) {
  if (!data.اسم_الطالب || data.اسم_الطالب.trim().split(" ").length < 3) {
    return { صحيح: false, رسالة: "يجب إدخال اسم الطالب ثلاثياً على الأقل" };
  }

  const هوية = String(data.رقم_الهوية || "").replace(/\D/g, "");
  if (هوية.length < 8 || هوية.length > 12) {
    return { صحيح: false, رسالة: "رقم الهوية يجب أن يكون بين 8 و 12 رقماً" };
  }

  if (data.رقم_جوال_الطالب) {
    const جوال = String(data.رقم_جوال_الطالب).replace(/\D/g, "");
    if (جوال.length !== 10) {
      return { صحيح: false, رسالة: "رقم جوال الطالب يجب أن يكون 10 أرقام" };
    }
  }

  const جوال_ولي = String(data.رقم_جوال_ولي_الامر || "").replace(/\D/g, "");
  if (جوال_ولي.length !== 10) {
    return { صحيح: false, رسالة: "رقم جوال ولي الأمر يجب أن يكون 10 أرقام" };
  }

  return { صحيح: true };
}

function بحث_عن_طالب(data) {
  const شيت_الطلاب = _getSheet(SHEETS.الطلاب);
  const شيت_ولي = _getSheet(SHEETS.اولياء_الامر);

  if (!شيت_الطلاب || شيت_الطلاب.getLastRow() <= 1) {
    return { نجاح: true, طالب: null };
  }

  const بيانات = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 60);
  const بحث_خام = String(data.بحث || "").trim();
  const بحث = بحث_خام.replace(/\D/g, "");
  const بحث_جوال = _normalizePhone(بحث);

  // البحث برقم هوية الطالب
  for (let i = 0; i < بيانات.length; i++) {
    const obj = بيانات[i];
    const هوية_الطالب = String(obj["رقم_الهوية"] || "").replace(/\D/g, "");
    const رقم_الطالب = String(obj["رقم_الطالب"] || "");

    if (هوية_الطالب && هوية_الطالب === بحث) {
      return { نجاح: true, طالب: بناء_كائن_طالب_من_كائن(obj, رقم_الطالب, شيت_ولي) };
    }
  }

  // البحث بجوال ولي الأمر بعد التطبيع
  if (شيت_ولي && شيت_ولي.getLastRow() > 1) {
    const بيانات_ولي = قراءة_كائنات_شيت_مع_كاش(SHEETS.اولياء_الامر, 60);

    for (let i = 0; i < بيانات_ولي.length; i++) {
      const ولي = بيانات_ولي[i];
      const جوال_الولي = _normalizePhone(ولي["رقم_جوال_ولي_الامر"]);

      if (جوال_الولي && جوال_الولي === بحث_جوال) {
        const رقم_الطالب = String(ولي["رقم_الطالب"] || "");
        const الطالب = بيانات.find(x => String(x["رقم_الطالب"] || "") === رقم_الطالب);

        if (الطالب) {
          return { نجاح: true, طالب: بناء_كائن_طالب_من_كائن(الطالب, رقم_الطالب, شيت_ولي) };
        }
      }
    }
  }

  return { نجاح: true, طالب: null };
}

function جلب_بيانات_طالب(data) {
  return بحث_عن_طالب(data);
}

function بناء_كائن_طالب(صف, رؤوس, رقم_الطالب, شيت_ولي) {
  const obj = {};
  رؤوس.forEach((عنوان, i) => { obj[عنوان] = صف[i]; });

  if (شيت_ولي && شيت_ولي.getLastRow() > 1) {
    const ولي = شيت_ولي.getDataRange().getValues();
    const رؤوس_ولي = ولي[0];
    for (let i = 1; i < ولي.length; i++) {
      if (String(ولي[i][رؤوس_ولي.indexOf("رقم_الطالب")] || "") === String(رقم_الطالب)) {
        رؤوس_ولي.forEach((ع, j) => {
          if (ع !== "رقم_الطالب") obj[ع] = ولي[i][j];
        });
        break;
      }
    }
  }
  return obj;
}

function بناء_كائن_طالب_من_كائن(الطالبObj, رقم_الطالب, شيت_ولي) {
  const obj = Object.assign({}, الطالبObj);

  if (شيت_ولي && شيت_ولي.getLastRow() > 1) {
    const أولياء = قراءة_كائنات_شيت_مع_كاش(SHEETS.اولياء_الامر, 60);
    const ولي = أولياء.find(w => String(w["رقم_الطالب"] || "") === String(رقم_الطالب));
