function جلب_الطلاب(data) {
  const all = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 45);
  let list = all.slice();

  const بحث = String(data.بحث || "").trim();
  const الحلقة = String(data.الحلقة || "").trim();
  const حالة_الطالب = String(data.حالة_الطالب || "").trim();
  const حفظ_اكثر_من = data.حفظ_اكثر_من !== undefined && data.حفظ_اكثر_من !== "" ? Number(data.حفظ_اكثر_من) : null;
  const حفظ_اقل_من = data.حفظ_اقل_من !== undefined && data.حفظ_اقل_من !== "" ? Number(data.حفظ_اقل_من) : null;
  const حجم_الصفحة = Math.max(Number(data.حجم_الصفحة || 50), 1);
  const الصفحة = Math.max(Number(data.الصفحة || 1), 1);

  if (بحث) {
    list = list.filter(ط =>
      String(ط["اسم_الطالب"] || "").includes(بحث) ||
      String(ط["رقم_الهوية"] || "").includes(بحث)
    );
  }

  if (الحلقة) {
    list = list.filter(ط => String(ط["الحلقة"] || "") === الحلقة);
  }

  if (حالة_الطالب) {
    list = list.filter(ط => String(ط["حالة_الطالب"] || "") === حالة_الطالب);
  }

  if (حفظ_اكثر_من !== null && !isNaN(حفظ_اكثر_من)) {
    list = list.filter(ط => Number(ط["مجموع_الحفظ"] || 0) > حفظ_اكثر_من);
  }

  if (حفظ_اقل_من !== null && !isNaN(حفظ_اقل_من)) {
    list = list.filter(ط => Number(ط["مجموع_الحفظ"] || 0) < حفظ_اقل_من);
  }

  list.sort((a, b) => String(a["اسم_الطالب"] || "").localeCompare(String(b["اسم_الطالب"] || ""), 'ar'));

  const المجموع = list.length;
  const عدد_الصفحات = Math.max(Math.ceil(المجموع / حجم_الصفحة), 1);
  const start = (الصفحة - 1) * حجم_الصفحة;
  const sliced = list.slice(start, start + حجم_الصفحة);

  return {
    نجاح: true,
    طلاب: sliced,
    المجموع,
    عدد_الصفحات,
    الصفحة,
  };
}


function تعبئة_بيانات_طالب_ناقصة(data) {
  const رقم_الطالب = String(data.رقم_الطالب || '').trim();
  const تعديلات = data.تعديلات || {};
  const تعديلات_ولي = data.تعديلات_ولي_الامر || {};

  if (!رقم_الطالب) {
    return { نجاح: false, خطأ: "رقم الطالب مطلوب" };
  }

  const شيت_الطلاب = _getSheet(SHEETS.الطلاب);
  const شيت_الولي = _getSheet(SHEETS.اولياء_الامر);

  const صف_طالب = جلب_صف_بـ(شيت_الطلاب, "رقم_الطالب", رقم_الطالب);
  if (!صف_طالب) {
    return { نجاح: false, خطأ: "الطالب غير موجود" };
  }

  let تم_التحديث = false;

  // يسمح فقط بتعبئة الحقول الفارغة في شيت الطلاب
  if (Object.keys(تعديلات).length) {
    const تحديثات_مسموحة = {};
    Object.keys(تعديلات).forEach(حقل => {
      const القيمة_الحالية = String(صف_طالب.بيانات?.[حقل] || '').trim();
      const القيمة_الجديدة = String(تعديلات[حقل] || '').trim();

      if (!القيمة_الجديدة) return;

      // يسمح فقط إذا كانت القيمة الحالية فارغة
      if (!القيمة_الحالية) {
        تحديثات_مسموحة[حقل] = القيمة_الجديدة;
      }
    });

    if (Object.keys(تحديثات_مسموحة).length) {
      _updateRowByHeader(SHEETS.الطلاب, صف_طالب.صف, تحديثات_مسموحة);
      تم_التحديث = true;
    }
  }

  // يسمح فقط بتعبئة الحقول الفارغة في شيت أولياء الأمور
  if (Object.keys(تعديلات_ولي).length) {
    const صف_ولي = جلب_صف_بـ(شيت_الولي, "رقم_الطالب", رقم_الطالب);

    if (صف_ولي) {
      const تحديثات_ولي_مسموحة = {};

      Object.keys(تعديلات_ولي).forEach(حقل => {
        const القيمة_الحالية = String(صف_ولي.بيانات?.[حقل] || '').trim();
        const القيمة_الجديدة = String(تعديلات_ولي[حقل] || '').trim();

        if (!القيمة_الجديدة) return;

        // يسمح فقط إذا كانت القيمة الحالية فارغة
        if (!القيمة_الحالية) {
          تحديثات_ولي_مسموحة[حقل] = القيمة_الجديدة;
        }
      });

      if (Object.keys(تحديثات_ولي_مسموحة).length) {
        _updateRowByHeader(SHEETS.اولياء_الامر, صف_ولي.صف, تحديثات_ولي_مسموحة);
        تم_التحديث = true;
      }
    }
  }

  if (!تم_التحديث) {
    return { نجاح: false, خطأ: "لا توجد حقول فارغة قابلة للتعبئة" };
  }

  تنظيف_كاش_شيتات();
  return { نجاح: true, رسالة: "تمت تعبئة البيانات الناقصة بنجاح" };
}

