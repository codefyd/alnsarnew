function جلب_بيانات_عامل(data) {
  const session = data._session || {};
  const rows = قراءة_كائنات_شيت_مع_كاش(SHEETS.العاملون, 30);
  const عامل = rows.find(x => String(x["الاسم"] || "") === String(session.الاسم || ""));
  return { نجاح: true, عامل: عامل || null };
}

function جلب_طلاب_الحلقة(data) {
  const session = data._session || {};
  const الحلقة_المطلوبة = String(data.الحلقة || session.الحلقة || "").trim();
  const role = String(session.الوظيفة || "");

  if (!الحلقة_المطلوبة) return { نجاح: true, طلاب: [] };

  if (role === "معلم" && String(session.الحلقة || "") !== الحلقة_المطلوبة) {
    return { نجاح: false, خطأ: "غير مصرح لك بعرض طلاب حلقة أخرى" };
  }

  const الطلاب = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 45)
    .filter(ط => String(ط["الحلقة"] || "") === الحلقة_المطلوبة)
    .sort((a, b) => String(a["اسم_الطالب"] || "").localeCompare(String(b["اسم_الطالب"] || ""), 'ar'));

  return { نجاح: true, طلاب: الطلاب };
}

function حفظ_ملاحظة_معلم(data) {
  const session = data._session || {};
  const role = String(session.الوظيفة || "");

  if (!["معلم","مشرف_تعليمي","مشرف_اداري","مدير"].includes(role)) {
    return { نجاح: false, خطأ: "غير مصرح لك بحفظ الملاحظات" };
  }

  const رقم_الطالب = data.رقم_الطالب;
  const ملاحظة = String(data.ملاحظة || "").trim();

  if (!رقم_الطالب) return { نجاح: false, خطأ: "رقم الطالب مطلوب" };

  const sh = _getSheet(SHEETS.الطلاب);
  const row = جلب_صف_بـ(sh, "رقم_الطالب", رقم_الطالب);
  if (!row) return { نجاح: false, خطأ: "الطالب غير موجود" };

  if (role === "معلم" && String(row.بيانات[row.رؤوس.indexOf("الحلقة")] || "") !== String(session.الحلقة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بالتعديل على طالب خارج حلقتك" };
  }

  const النص_الحالي = String(row.بيانات[row.رؤوس.indexOf("ملاحظات")] || "");
  const ختم = `[${new Date().toLocaleString("ar-SA")}] ${session.الاسم || "مستخدم"}: ${ملاحظة}`;
  const النص_الجديد = النص_الحالي ? `${النص_الحالي}\n${ختم}` : ختم;

  sh.getRange(row.صف, row.رؤوس.indexOf("ملاحظات") + 1).setValue(النص_الجديد);
  تنظيف_كاش_شيتات();

  return { نجاح: true, رسالة: "تم حفظ الملاحظة" };
}

