function تعديل_جماعي_طلاب(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بالتعديل الجماعي" };
  }

  const ids = Array.isArray(data.أرقام_الطلاب) ? data.أرقام_الطلاب : [];
  const تعديلات = data.تعديلات || {};
  if (!ids.length) return { نجاح: false, خطأ: "لم يتم تحديد طلاب" };
  if (!Object.keys(تعديلات).length) return { نجاح: false, خطأ: "لا توجد تعديلات" };

  const sh = _getSheet(SHEETS.الطلاب);
  const values = sh.getDataRange().getValues();
  const headers = values[0];

  const mapHeaderIndex = {};
  Object.keys(تعديلات).forEach(k => {
    const idx = headers.indexOf(k);
    if (idx !== -1) mapHeaderIndex[k] = idx;
  });

  if (!Object.keys(mapHeaderIndex).length) {
    return { نجاح: false, خطأ: "حقول التعديل غير صالحة" };
  }

  const idxStudentId = headers.indexOf("رقم_الطالب");
  let updatedCount = 0;

  for (let i = 1; i < values.length; i++) {
    const rowStudentId = String(values[i][idxStudentId] || "");
    if (ids.includes(rowStudentId)) {
      Object.keys(mapHeaderIndex).forEach(k => {
        values[i][mapHeaderIndex[k]] = تعديلات[k];
      });
      updatedCount++;
    }
  }

  sh.getRange(1, 1, values.length, values[0].length).setValues(values);
  تنظيف_كاش_شيتات();

  return {
    نجاح: true,
    رسالة: `تم تحديث ${updatedCount} طالب بنجاح`,
    عدد_المحدّثين: updatedCount
  };
}

function تصدير_الطلاب_csv(data) {
  const session = data._session || {};
  if (!_isAdminRole(session.الوظيفة || "")) {
    return { نجاح: false, خطأ: "غير مصرح لك بتصدير البيانات" };
  }

  const rows = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 30);
  if (!rows.length) return { نجاح: true, csv: "" };

  const headers = Object.keys(rows[0]).filter(k => k !== "_صف");
  const csvLines = [headers.join(",")];

  rows.forEach(r => {
    const line = headers.map(h => {
      const v = String(r[h] == null ? "" : r[h]).replace(/"/g, '""');
      return `"${v}"`;
    }).join(",");
    csvLines.push(line);
  });

  return {
    نجاح: true,
    csv: csvLines.join("\n")
  };
}

