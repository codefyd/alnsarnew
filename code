function جلب_تقارير_مشرف_اداري(data) {
  const الطلاب = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 20);
  const الطلبات = قراءة_كائنات_شيت_مع_كاش(SHEETS.طلبات_التسجيل, 20);
  const الانذارات_التعليمية = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_التعليمية, 20);
  const الانذارات_الادارية = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_الادارية, 20);

  const تقارير = {
    إجمالي_الطلاب: الطلاب.length,
    طلاب_منتظمون: الطلاب.filter(x => String(x["حالة_الطالب"] || "") === "منتظم").length,
    طلاب_موقوفون: الطلاب.filter(x => String(x["حالة_الطالب"] || "") === "موقوف").length,
    طلبات_جديدة: الطلبات.filter(x => String(x["حالة_الطلب"] || "") === "جديد").length,
    طلبات_انتظار: الطلبات.filter(x => String(x["حالة_الطلب"] || "") === "انتظار").length,
    ارشيف_تأخر: الانذارات_الادارية.filter(x => String(x["نوع_الانذار"] || "") === "تأخر").length,
    ارشيف_غياب: الانذارات_الادارية.filter(x => String(x["نوع_الانذار"] || "") === "غياب").length,
    ارشيف_عذر: الانذارات_الادارية.filter(x => String(x["نوع_الانذار"] || "") === "غياب_بعذر").length,
    انذ_تعليمية_مفتوحة: الانذارات_التعليمية.filter(x => !String(x["تاريخ_الإغلاق"] || "")).length,
    إنذارات_اداري_تأخر_مستحقة: جلب_مستحقي_الانذار_الاداري({ نوع: "تأخر", _session: data._session || {} }).طلاب?.length || 0,
    إنذارات_اداري_غياب_مستحقة: جلب_مستحقي_الانذار_الاداري({ نوع: "غياب", _session: data._session || {} }).طلاب?.length || 0,
    إنذارات_اداري_عذر_مستحقة: جلب_مستحقي_الانذار_الاداري({ نوع: "غياب_بعذر", _session: data._session || {} }).طلاب?.length || 0,
  };

  return { نجاح: true, تقارير };
}

function جلب_تقارير_مشرف_تعليمي(data) {
  const الطلاب = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 20);
  const الانذارات = قراءة_كائنات_شيت_مع_كاش(SHEETS.الانذارات_التعليمية, 20);

  const تقارير = {
    إجمالي_الطلاب: الطلاب.length,
    الإنذارات_التعليمية_كلها: الانذارات.length,
    الإنذارات_التعليمية_المفتوحة: الانذارات.filter(x => !String(x["تاريخ_الإغلاق"] || "")).length,
    الإنذارات_التعليمية_المغلقة: الانذارات.filter(x => String(x["تاريخ_الإغلاق"] || "")).length,
  };

  return { نجاح: true, تقارير };
}

function جلب_تقارير_معلم(data) {
  const الحلقة = String(data.الحلقة || "").trim();
  if (!الحلقة) return { نجاح: true, تقارير: {} };

  const الطلاب = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 20)
    .filter(x => String(x["الحلقة"] || "") === الحلقة);

  const ids = الطلاب.map(x => String(x["رقم_الطالب"] || ""));
  const الحضور = قراءة_كائنات_شيت_مع_كاش(SHEETS.سجل_الحضور, 20)
    .filter(x => ids.includes(String(x["رقم_الطالب"] || "")));

  const تقارير = {
    إجمالي_الطلاب: الطلاب.length,
    المنتظمون: الطلاب.filter(x => String(x["حالة_الطالب"] || "") === "منتظم").length,
    غير_منتظمين: الطلاب.filter(x => String(x["حالة_الطالب"] || "") === "غير منتظم").length,
    موقوفون: الطلاب.filter(x => String(x["حالة_الطالب"] || "") === "موقوف").length,
    حضور: الحضور.filter(x => String(x["نوع_الغياب"] || "") === "حضور").length,
    غياب: الحضور.filter(x => String(x["نوع_الغياب"] || "") === "غياب").length,
    غياب_بعذر: الحضور.filter(x => String(x["نوع_الغياب"] || "") === "غياب_بعذر").length,
    تأخر: الحضور.filter(x => String(x["نوع_الغياب"] || "") === "تأخر").length,
  };

  return { نجاح: true, تقارير };
}

function جلب_بيانات_الإنجازات_العامة(data) {
  const طلاب = قراءة_كائنات_شيت_مع_كاش(SHEETS.الطلاب, 60);
  const حلق = قراءة_كائنات_شيت_مع_كاش(SHEETS.الحلق, 60);
  const عاملون = قراءة_كائنات_شيت_مع_كاش(SHEETS.العاملون, 60);

  const إجمالي_الطلاب = طلاب.length;
  const عدد_الحلق = حلق.length;

  const مجموع_الحفظ = طلاب.reduce(function(sum, ط) {
    return sum + Number(ط["مجموع_الحفظ"] || 0);
  }, 0);

  const المنتظمون = طلاب.filter(function(ط) {
    return String(ط["حالة_الطالب"] || "") === "منتظم";
  }).length;

  const عدد_العاملين = عاملون.filter(function(ع) {
    return String(ع["نشط"] || "") === "نعم" &&
      ["معلم","مشرف_تعليمي","مشرف_اداري","مدير"].includes(String(ع["الوظيفة"] || ""));
  }).length;

  const متوسط_الحفظ = إجمالي_الطلاب
    ? (مجموع_الحفظ / إجمالي_الطلاب).toFixed(1)
    : 0;

  const ترتيب = طلاب
    .filter(function(ط) {
      return Number(ط["مجموع_الحفظ"] || 0) > 0;
    })
    .sort(function(a, b) {
      return Number(b["مجموع_الحفظ"] || 0) - Number(a["مجموع_الحفظ"] || 0);
    })
    .slice(0, 10)
    .map(function(ط) {
      return {
        "اسم_الطالب": ط["اسم_الطالب"] || "",
        "الحلقة": ط["الحلقة"] || "",
        "مجموع_الحفظ": Number(ط["مجموع_الحفظ"] || 0)
      };
    });

  const حلق_مع_إحصاءات = حلق.map(function(ح) {
    const طلاب_الحلقة = طلاب.filter(function(ط) {
      return String(ط["الحلقة"] || "") === String(ح["اسم_الحلقة"] || "");
    });

    const عدد_طلاب_الحلقة = طلاب_الحلقة.length;

    const مجموع_حفظ_الحلقة = طلاب_الحلقة.reduce(function(sum, ط) {
      return sum + Number(ط["مجموع_الحفظ"] || 0);
    }, 0);

    const متوسط_حفظ_الحلقة = عدد_طلاب_الحلقة
      ? (مجموع_حفظ_الحلقة / عدد_طلاب_الحلقة).toFixed(1)
      : 0;

    return {
      "اسم_الحلقة": ح["اسم_الحلقة"] || "",
      "المعلم": ح["المعلم"] || "",
      "عدد_الطلاب": عدد_طلاب_الحلقة,
      "مجموع_الحفظ": مجموع_حفظ_الحلقة,
      "متوسط_الحفظ": متوسط_حفظ_الحلقة
    };
  });

  return {
    نجاح: true,
    إجمالي_الطلاب: إجمالي_الطلاب,
    عدد_الحلق: عدد_الحلق,
    مجموع_الحفظ: مجموع_الحفظ,
    المنتظمون: المنتظمون,
    عدد_العاملين: عدد_العاملين,
    متوسط_الحفظ: متوسط_الحفظ,
    ترتيب: ترتيب,
    حلق: حلق_مع_إحصاءات
  };
}
